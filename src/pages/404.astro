---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Seite nicht gefunden – Mauckert Gallery" description="Diese Seite gibt es leider nicht.">
  <div class="container">
    <div class="notfound">
      <p class="nf-code">404</p>
      <h1>Diese Seite gibt es leider nicht</h1>
      <p class="nf-text">
        Vielleicht wurde sie verschoben oder das Werk ist nicht mehr verfügbar.
        Schauen Sie sich gern in der Galerie um.
      </p>
      <div class="nf-actions">
        <a class="btn" href="/galerie/">Zur Galerie</a>
        <a class="btn btn-ghost" href="/">Zur Startseite</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding: 5rem 0 6rem;
    max-width: 560px;
    margin: 0 auto;
  }
  .nf-code {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 12vw, 7rem);
    line-height: 1;
    color: var(--clay);
    margin: 0 0 0.5rem;
  }
  .nf-text { color: var(--stone); margin: 1rem auto 2rem; }
  .nf-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
