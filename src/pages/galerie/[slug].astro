---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArtworkCard from "../../components/ArtworkCard.astro";
import { artworks, formatPrice, primaryImage } from "../../lib/artworks";
import { artworkInquiryMailto, similarWorkMailto } from "../../lib/contact";

export function getStaticPaths() {
  return artworks.map((a) => ({ params: { slug: a.slug }, props: { artwork: a } }));
}

const { artwork } = Astro.props;
const main = primaryImage(artwork);
const sold = artwork.in_stock === false;

// The descriptions in artworks.json contain HTML (e.g. <p>…</p>); strip it for
// meta description and alt text.
const plainDescription = (artwork.description || "")
  .replace(/<[^>]*>/g, " ")
  .replace(/&nbsp;/gi, " ")
  .replace(/&amp;/gi, "&")
  .replace(/&quot;/gi, '"')
  .replace(/&#39;/g, "'")
  .replace(/&lt;/gi, "<")
  .replace(/&gt;/gi, ">")
  .replace(/\s+/g, " ")
  .trim();
const categoryLabel = artwork.categories.join(", ");
// Some works (esp. sold ones) carry price 0 — treat that as "no real price".
const hasPrice = artwork.price != null && artwork.price > 0;
const priceLabel = hasPrice ? formatPrice(artwork) : sold ? "Verkauft" : "Preis auf Anfrage";
const detailUrl = new URL(`/galerie/${artwork.slug}/`, Astro.site).toString();
const mailto = artworkInquiryMailto({ name: artwork.name, price: priceLabel, url: detailUrl });
const similarMailto = similarWorkMailto({ name: artwork.name, url: detailUrl });

// "Ähnliche Werke": gleiche Kategorie zuerst, verfügbare bevorzugt, dann auffüllen.
const isAvail = (a: typeof artwork) => a.in_stock !== false;
const sameCat = artworks.filter(
  (a) => a.slug !== artwork.slug && a.category_slugs.some((s) => artwork.category_slugs.includes(s)),
);
const others = artworks.filter((a) => a.slug !== artwork.slug && !sameCat.includes(a));
const related = [
  ...sameCat.filter(isAvail),
  ...sameCat.filter((a) => !isAvail(a)),
  ...others.filter(isAvail),
].slice(0, 3);
const metaDescription =
  [`${artwork.name} – ${categoryLabel ? categoryLabel + ", " : ""}Original von Ute Mauckert.`, plainDescription, priceLabel]
    .filter(Boolean)
    .join(" ")
    .slice(0, 300);
const altText = `${artwork.name}${categoryLabel ? ` – ${categoryLabel}` : ""} von Ute Mauckert`;

const artworkLd = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  name: artwork.name,
  ...(plainDescription ? { description: plainDescription } : {}),
  ...(categoryLabel ? { artform: categoryLabel, artMedium: categoryLabel } : {}),
  image: new URL(main, Astro.site).toString(),
  url: new URL(`/galerie/${artwork.slug}/`, Astro.site).toString(),
  creator: { "@type": "Person", name: "Ute Mauckert" },
  ...(hasPrice
    ? {
        offers: {
          "@type": "Offer",
          price: artwork.price,
          priceCurrency: artwork.currency || "EUR",
          availability: artwork.in_stock
            ? "https://schema.org/InStock"
            : "https://schema.org/SoldOut",
          url: new URL(`/galerie/${artwork.slug}/`, Astro.site).toString(),
        },
      }
    : {}),
};
---
<BaseLayout
  title={`${artwork.name} – Mauckert Gallery`}
  description={metaDescription}
  type="article"
  image={main}
  jsonLd={artworkLd}
>
  <div class="container artwork-detail">
    <div class="images">
      {artwork.media.map((m, i) => (
        <img src={m.local_path || m.display_url} alt={altText} loading={i === 0 ? "eager" : "lazy"} />
      ))}
    </div>
    <aside class="info">
      <h1>{artwork.name}</h1>
      {artwork.categories.length > 0 && (
        <p class="eyebrow">{artwork.categories.join(" · ")}</p>
      )}
      {plainDescription && <p>{plainDescription}</p>}

      {sold ? (
        <>
          <div class="price price-sold">Verkauft</div>
          <a class="btn btn-ghost" href={similarMailto}>Ähnliches Werk anfragen</a>
          <p class="buy-trust">Original · handsigniert · mit Echtheitszertifikat</p>
        </>
      ) : (
        <>
          <div class="price">{priceLabel}</div>
          <a class="btn" href={mailto}>Anfragen</a>
          <p class="buy-trust">Original · handsigniert · mit Echtheitszertifikat · Versand nach Absprache</p>
        </>
      )}

      <p style="margin-top:2rem;"><a href="/galerie/" style="color:var(--muted);">← Zurück zur Galerie</a></p>
    </aside>
  </div>

  {related.length > 0 && (
    <section class="related container">
      <h2 class="section-title">Ähnliche Werke</h2>
      <div class="grid-artworks">
        {related.map((a) => <ArtworkCard artwork={a} />)}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .related { margin-top: 4rem; }
  .related .section-title { margin-bottom: 1.5rem; }
</style>
