---
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/500.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  theme?: "light" | "dark";
  /** OG/Twitter share image, relative to the site root. */
  image?: string;
  /** og:type — "website" for normal pages, "article" for artwork/exhibition detail. */
  type?: "website" | "article";
  /** Extra page-specific JSON-LD (e.g. a VisualArtwork). Single object or array. */
  jsonLd?: object | object[];
}
const {
  title,
  description = "Mauckert Gallery – Malerei und Zeichnung von Ute Mauckert. Klassisch geschult, vor Ort gemalt, aus dem Rheintal.",
  theme = "light",
  image = "/og-image.jpg",
  type = "website",
  jsonLd,
} = Astro.props;
const path = Astro.url.pathname;
const site = Astro.site ?? new URL("https://www.mauckertgallery.com");
const canonical = new URL(path, site).toString();
const ogImage = new URL(image, site).toString();
const isDefaultOg = image === "/og-image.jpg";

// Site-wide structured data: the artist (Person) + the website itself.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ute Mauckert",
  jobTitle: "Malerin und Zeichnerin",
  description:
    "Malerin und Zeichnerin aus dem Rheintal – klassisch geschult (Architektur an der Bauhaus-Universität Weimar), mit Schwerpunkt auf Zeichnung, Aquarell, Pastell und Acryl.",
  url: site.toString(),
  image: new URL("/og-image.jpg", site).toString(),
  knowsAbout: ["Malerei", "Zeichnung", "Aquarell", "Pastell", "Urban Sketching", "Aktzeichnung", "Porträt"],
  address: {
    "@type": "PostalAddress",
    streetAddress: "Schillerstraße 26",
    postalCode: "55413",
    addressLocality: "Weiler bei Bingen",
    addressRegion: "Rheinland-Pfalz",
    addressCountry: "DE",
  },
  email: "s.mauckert@web.de",
  telephone: "+491726128239",
};
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Mauckert Gallery",
  url: site.toString(),
  inLanguage: "de-DE",
  about: { "@type": "Person", name: "Ute Mauckert" },
};
const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allLd = [personLd, websiteLd, ...extraLd];

// Cloudflare Web Analytics (cookielos, anonym). Token aus dem Cloudflare-Dashboard
// (Analytics & Logs → Web Analytics → Add a site → Token kopieren) hier eintragen.
// Leer lassen = Messung deaktiviert (kein Beacon wird geladen).
const cfAnalyticsToken = "6ad83ec2829a419e9243a94c561812ee";
function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
const nav = [
  { href: "/", label: "Home" },
  { href: "/galerie", label: "Galerie" },
  { href: "/vita", label: "Vita" },
  { href: "/ausstellungen", label: "Ausstellungen" },
  { href: "/kontakt", label: "Kontakt" },
];
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#121920" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Mauckert Gallery" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {isDefaultOg && <meta property="og:image:width" content="1200" />}
    {isDefaultOg && <meta property="og:image:height" content="630" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    {allLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class={theme === "dark" ? "theme-dark" : ""}>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/" aria-label="Mauckert Gallery – Startseite">
          <svg class="brand-mark" viewBox="0 0 218 212" aria-hidden="true" focusable="false">
            <g transform="translate(0,212) scale(0.1,-0.1)" fill="currentColor" stroke="none">
              <path d="M2059 1966 c-2 -3 -441 -6 -974 -7 l-970 -2 2 -926 c2 -509 5 -925 8 -923 3 1 445 2 984 2 l978 0 2 483 1 482 -202 -3 c-157 -3 -203 0 -209 10 -5 7 -9 115 -9 241 0 125 -4 227 -8 227 -4 0 -30 -23 -57 -51 -28 -28 -106 -98 -175 -156 -69 -57 -169 -147 -222 -199 -53 -52 -100 -94 -105 -94 -5 0 -58 50 -118 111 -61 61 -159 153 -220 204 -60 51 -123 107 -140 125 -16 17 -41 40 -55 50 l-25 18 0 -127 c1 -69 2 -296 3 -503 l2 -377 105 -3 105 -3 0 283 c0 155 4 282 8 282 4 0 79 -70 167 -155 88 -85 167 -154 175 -155 9 0 24 16 35 36 22 40 85 108 160 171 102 86 150 123 156 123 15 0 21 -87 13 -189 -8 -104 -7 -342 2 -371 3 -11 23 -16 81 -18 43 -2 86 -5 96 -8 16 -5 17 7 17 160 l0 166 100 0 100 0 0 -270 0 -270 -770 0 -770 0 0 703 0 703 770 3 770 3 0 -251 0 -251 105 3 104 2 7 28 c3 15 4 178 2 362 -3 314 -6 353 -29 331z"/>
            </g>
          </svg>
          <span class="brand-text">Mauckert Gallery</span>
        </a>
        <button
          type="button"
          class="nav-toggle"
          id="nav-toggle"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="primary-nav"
        >
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
        <nav class="nav" id="primary-nav">
          {nav.map((n) => (
            <a href={n.href} class={isActive(n.href) ? "active" : ""}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <script is:inline>
      (() => {
        const btn = document.getElementById("nav-toggle");
        const header = document.querySelector(".site-header");
        if (!btn || !header) return;
        const setOpen = (open) => {
          header.classList.toggle("nav-open", open);
          btn.setAttribute("aria-expanded", open ? "true" : "false");
          btn.setAttribute("aria-label", open ? "Menü schließen" : "Menü öffnen");
        };
        btn.addEventListener("click", () => setOpen(!header.classList.contains("nav-open")));
        document.getElementById("primary-nav")?.addEventListener("click", (e) => {
          if (e.target instanceof HTMLAnchorElement) setOpen(false);
        });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") setOpen(false); });
      })();
    </script>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <div>&copy; {new Date().getFullYear()} Mauckert Gallery</div>
        <div><a href="/impressum">Impressum</a> · <a href="/datenschutz">Datenschutz</a></div>
      </div>
    </footer>
    {cfAnalyticsToken && (
      <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}></script>
    )}
    {import.meta.env.DEV && (
      <a
        href="/werk-erfassen"
        title="Werk-Erfassen (nur lokal)"
        style="position:fixed;right:18px;bottom:18px;z-index:9999;background:#2f4f4f;color:#fff;padding:12px 18px;border-radius:999px;font:600 14px/1 Inter,system-ui,sans-serif;text-decoration:none;box-shadow:0 4px 14px rgba(0,0,0,.25);"
      >
        ✎ Werk erfassen
      </a>
    )}
  </body>
</html>
