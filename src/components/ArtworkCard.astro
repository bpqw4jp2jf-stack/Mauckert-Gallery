---
import type { Artwork } from "../lib/artworks";
import { primaryImage, formatPrice } from "../lib/artworks";

interface Props {
  artwork: Artwork;
  badge?: string | null;
  sold?: boolean;
}
const { artwork, badge = null, sold = false } = Astro.props;
// A work counts as sold if explicitly flagged OR marked out of stock in the data.
const isSold = sold || artwork.in_stock === false;
const img = primaryImage(artwork);
const altText = `${artwork.name}${artwork.categories.length ? ` – ${artwork.categories.join(", ")}` : ""} von Ute Mauckert`;
---
<a
  class="artwork-card"
  href={`/galerie/${artwork.slug}/`}
  data-available={(!isSold).toString()}
  data-price={artwork.price ?? ""}
  data-title={artwork.name}
>
  <div class="frame">
    {img && <img src={img} alt={altText} loading="lazy" />}
    {badge && <span class={`badge${isSold ? " badge-sold" : ""}`}>{badge}</span>}
    {isSold && !badge && <span class="badge badge-sold">Verkauft</span>}
  </div>
  <div class="meta">
    <span class="title">{artwork.name}</span>
    <span class="price">{isSold ? "Verkauft" : formatPrice(artwork)}</span>
  </div>
</a>
